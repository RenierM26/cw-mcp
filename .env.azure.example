# Non-secret app settings for Azure Container Apps
TRANSPORT=http
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
AUTH_ENABLED=true
AUTH_ALLOWED_IPS=
AUTH_TRUST_X_FORWARDED_FOR=true
CW_BASE_URL=https://your-company.connectwise.com/v4_6_release/apis/3.0
CW_COMPANY_ID=your_company_id
CW_CLIENT_ID=your_client_id
CW_API_VERSION=2024.1
CW_TIMEOUT_SECONDS=30
CW_PAGE_SIZE=50
CW_MAX_PAGE_SIZE=100

# Secrets should come from Container App secrets or Key Vault references
CW_PUBLIC_KEY=replace-with-secretref
CW_PRIVATE_KEY=replace-with-secretref
AUTH_BEARER_TOKEN=replace-with-secretref
